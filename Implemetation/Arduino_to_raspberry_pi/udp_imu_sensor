#include <WiFiNINA.h>
#include <WiFiUdp.h>
#include <Wire.h>
#include <math.h>

// =======================
// WiFi settings
// =======================
char ssid[] = "Faysal";
char pass[] = "87654321";

// =======================
// Raspberry Pi UDP settings
// =======================
IPAddress piIP(10, 153, 76, 64);
const unsigned int piPort = 6000;
const unsigned int localPort = 6001;

// =======================
// MPU6050 settings
// =======================
uint8_t MPU_ADDR = 0x68;
bool accelAvailable = false;

// Gravity constant
const float G = 9.80665;

// MPU6050 ±4g scale = 8192 LSB/g
const float ACCEL_SCALE = 8192.0;

// Vibration sampling settings
const int VIBRATION_SAMPLES = 50;
const int SAMPLE_DELAY_MS = 10;

// Thresholds in m/s^2 RMS
const float NORMAL_LIMIT = 0.25;
const float WARNING_LIMIT = 0.80;

// Calibration baseline
float baseAx = 0.0;
float baseAy = 0.0;
float baseAz = 0.0;
float baselineMagnitude = 9.81;

WiFiUDP udp;

// =======================
// WiFi connection
// =======================
void connectWiFi() {
  Serial.println();
  Serial.print("Connecting to WiFi: ");
  Serial.println(ssid);

  WiFi.disconnect();
  delay(1000);

  int attempt = 0;

  while (WiFi.status() != WL_CONNECTED && attempt < 30) {
    WiFi.begin(ssid, pass);

    Serial.print("Attempt ");
    Serial.print(attempt + 1);
    Serial.print(": ");

    int waitCount = 0;

    while (WiFi.status() != WL_CONNECTED && waitCount < 5) {
      Serial.print(".");
      delay(1000);
      waitCount++;
    }

    Serial.println();

    if (WiFi.status() == WL_CONNECTED) {
      break;
    }

    attempt++;
    delay(1000);
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("WiFi connected successfully!");
    Serial.print("Arduino IP: ");
    Serial.println(WiFi.localIP());
    Serial.print("Target Raspberry Pi IP: ");
    Serial.println(piIP);
  } else {
    Serial.println("WiFi connection failed.");
    while (1) {
      delay(1000);
    }
  }
}

// =======================
// I2C write 8-bit
// =======================
bool writeI2C8(uint8_t deviceAddr, uint8_t reg, uint8_t value) {
  Wire.beginTransmission(deviceAddr);
  Wire.write(reg);
  Wire.write(value);
  byte error = Wire.endTransmission();

  return error == 0;
}

// =======================
// I2C read 8-bit
// =======================
uint8_t readI2C8(uint8_t deviceAddr, uint8_t reg) {
  Wire.beginTransmission(deviceAddr);
  Wire.write(reg);

  byte error = Wire.endTransmission(false);

  if (error != 0) {
    return 0;
  }

  Wire.requestFrom((uint8_t)deviceAddr, (size_t)1, true);

  if (Wire.available() < 1) {
    return 0;
  }

  return Wire.read();
}

// =======================
// Read raw accelerometer data
// =======================
bool readRawAcceleration(int16_t &rawAx, int16_t &rawAy, int16_t &rawAz) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);

  byte error = Wire.endTransmission(false);

  if (error != 0) {
    return false;
  }

  Wire.requestFrom((uint8_t)MPU_ADDR, (size_t)6, true);

  if (Wire.available() < 6) {
    return false;
  }

  uint8_t axH = Wire.read();
  uint8_t axL = Wire.read();
  uint8_t ayH = Wire.read();
  uint8_t ayL = Wire.read();
  uint8_t azH = Wire.read();
  uint8_t azL = Wire.read();

  rawAx = (int16_t)((axH << 8) | axL);
  rawAy = (int16_t)((ayH << 8) | ayL);
  rawAz = (int16_t)((azH << 8) | azL);

  return true;
}

// =======================
// Read acceleration in m/s^2
// =======================
bool readAcceleration(float &ax, float &ay, float &az, float &magnitude) {
  int16_t rawAx, rawAy, rawAz;

  if (!readRawAcceleration(rawAx, rawAy, rawAz)) {
    return false;
  }

  ax = (rawAx / ACCEL_SCALE) * G;
  ay = (rawAy / ACCEL_SCALE) * G;
  az = (rawAz / ACCEL_SCALE) * G;

  magnitude = sqrt((ax * ax) + (ay * ay) + (az * az));

  return true;
}

// =======================
// Scan for MPU6050
// =======================
void scanAccelerometer() {
  Serial.println();
  Serial.println("Scanning I2C bus for MPU6050...");

  accelAvailable = false;

  for (uint8_t address = 1; address < 127; address++) {
    Wire.beginTransmission(address);
    byte error = Wire.endTransmission();

    if (error == 0) {
      Serial.print("I2C device found at address 0x");

      if (address < 16) {
        Serial.print("0");
      }

      Serial.println(address, HEX);

      if (address == 0x68 || address == 0x69) {
        MPU_ADDR = address;
        accelAvailable = true;
      }
    }
  }

  if (accelAvailable) {
    Serial.print("MPU6050 found at address 0x");
    Serial.println(MPU_ADDR, HEX);
  } else {
    Serial.println("MPU6050 not found at 0x68 or 0x69.");
  }
}

// =======================
// Initialize MPU6050
// =======================
void initAccelerometer() {
  Serial.println();
  Serial.println("Initializing MPU6050...");

  Wire.begin();
  Wire.setClock(400000);
  delay(500);

  scanAccelerometer();

  if (!accelAvailable) {
    Serial.println("Program stopped. MPU6050 not found.");
    while (1) {
      delay(1000);
    }
  }

  uint8_t whoami = readI2C8(MPU_ADDR, 0x75);
  Serial.print("WHO_AM_I = 0x");
  Serial.println(whoami, HEX);

  if (whoami != 0x68 && whoami != 0x69) {
    Serial.println("Warning: WHO_AM_I value is unexpected.");
  }

  // Reset MPU6050
  writeI2C8(MPU_ADDR, 0x6B, 0x80);
  delay(200);

  // Wake up MPU6050
  writeI2C8(MPU_ADDR, 0x6B, 0x00);
  delay(100);

  // Use PLL clock
  writeI2C8(MPU_ADDR, 0x6B, 0x01);
  delay(100);

  // Digital low-pass filter
  writeI2C8(MPU_ADDR, 0x1A, 0x03);
  delay(50);

  // Sample rate = 1 kHz / (1 + 9) = 100 Hz
  writeI2C8(MPU_ADDR, 0x19, 0x09);
  delay(50);

  // Accelerometer range ±4g
  writeI2C8(MPU_ADDR, 0x1C, 0x08);
  delay(50);

  Serial.println("MPU6050 initialized for vibration measurement.");
}

// =======================
// Calibrate baseline
// =======================
void calibrateBaseline() {
  Serial.println();
  Serial.println("Calibrating accelerometer baseline...");
  Serial.println("Keep the sensor completely still for 5 seconds.");

  float sumAx = 0.0;
  float sumAy = 0.0;
  float sumAz = 0.0;
  float sumMag = 0.0;

  int validSamples = 0;
  int samples = 200;

  for (int i = 0; i < samples; i++) {
    float ax, ay, az, magnitude;

    if (readAcceleration(ax, ay, az, magnitude)) {
      sumAx += ax;
      sumAy += ay;
      sumAz += az;
      sumMag += magnitude;
      validSamples++;
    }

    delay(25);
  }

  if (validSamples > 0) {
    baseAx = sumAx / validSamples;
    baseAy = sumAy / validSamples;
    baseAz = sumAz / validSamples;
    baselineMagnitude = sumMag / validSamples;
  }

  Serial.println("Calibration done.");
  Serial.print("Base AX             : ");
  Serial.print(baseAx, 3);
  Serial.println(" m/s^2");

  Serial.print("Base AY             : ");
  Serial.print(baseAy, 3);
  Serial.println(" m/s^2");

  Serial.print("Base AZ             : ");
  Serial.print(baseAz, 3);
  Serial.println(" m/s^2");

  Serial.print("Baseline Magnitude  : ");
  Serial.print(baselineMagnitude, 3);
  Serial.println(" m/s^2");
}

// =======================
// Measure vibration
// =======================
bool measureVibration(
  float &lastAx,
  float &lastAy,
  float &lastAz,
  float &lastMagnitude,
  float &vibrationRMS,
  float &vibrationPeak,
  float &magnitudePeakToPeak,
  int &validSamples
) {
  float sumSquare = 0.0;
  float peakDynamic = 0.0;

  float minMagnitude = 9999.0;
  float maxMagnitude = -9999.0;

  validSamples = 0;

  for (int i = 0; i < VIBRATION_SAMPLES; i++) {
    float ax, ay, az, magnitude;

    if (readAcceleration(ax, ay, az, magnitude)) {
      lastAx = ax;
      lastAy = ay;
      lastAz = az;
      lastMagnitude = magnitude;

      // Remove static gravity/baseline vector
      float dx = ax - baseAx;
      float dy = ay - baseAy;
      float dz = az - baseAz;

      // Dynamic acceleration = vibration
      float dynamicAccel = sqrt((dx * dx) + (dy * dy) + (dz * dz));

      sumSquare += dynamicAccel * dynamicAccel;

      if (dynamicAccel > peakDynamic) {
        peakDynamic = dynamicAccel;
      }

      if (magnitude < minMagnitude) {
        minMagnitude = magnitude;
      }

      if (magnitude > maxMagnitude) {
        maxMagnitude = magnitude;
      }

      validSamples++;
    }

    delay(SAMPLE_DELAY_MS);
  }

  if (validSamples == 0) {
    return false;
  }

  vibrationRMS = sqrt(sumSquare / validSamples);
  vibrationPeak = peakDynamic;
  magnitudePeakToPeak = maxMagnitude - minMagnitude;

  return true;
}

// =======================
// Get vibration status
// =======================
String getVibrationStatus(float vibrationRMS) {
  if (vibrationRMS < NORMAL_LIMIT) {
    return "NORMAL";
  } else if (vibrationRMS < WARNING_LIMIT) {
    return "WARNING";
  } else {
    return "CRITICAL";
  }
}

// =======================
// Send UDP
// =======================
void sendUDP(String payload) {
  udp.beginPacket(piIP, piPort);
  udp.print(payload);
  udp.endPacket();
}

// =======================
// Organized Serial Monitor Output
// =======================
void printOrganizedData(
  float ax,
  float ay,
  float az,
  float accelMagnitude,
  float vibrationRMS,
  float vibrationG,
  float vibrationPeak,
  float magnitudePeakToPeak,
  String vibrationStatus,
  int validSamples,
  String payload
) {
  Serial.println();
  Serial.println("============================================================");
  Serial.println("                    VIBRATION SENSOR DATA");
  Serial.println("============================================================");

  Serial.print("WiFi Status         : ");
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("CONNECTED");
  } else {
    Serial.println("DISCONNECTED");
  }

  Serial.print("Arduino IP          : ");
  Serial.println(WiFi.localIP());

  Serial.print("UDP Target          : ");
  Serial.print(piIP);
  Serial.print(":");
  Serial.println(piPort);

  Serial.println("------------------------------------------------------------");
  Serial.println("ACCELEROMETER");
  Serial.println("------------------------------------------------------------");

  Serial.print("Samples             : ");
  Serial.println(validSamples);

  Serial.print("AX                  : ");
  Serial.print(ax, 3);
  Serial.println(" m/s^2");

  Serial.print("AY                  : ");
  Serial.print(ay, 3);
  Serial.println(" m/s^2");

  Serial.print("AZ                  : ");
  Serial.print(az, 3);
  Serial.println(" m/s^2");

  Serial.print("Accel Magnitude     : ");
  Serial.print(accelMagnitude, 3);
  Serial.println(" m/s^2");

  Serial.print("Baseline Magnitude  : ");
  Serial.print(baselineMagnitude, 3);
  Serial.println(" m/s^2");

  Serial.println("------------------------------------------------------------");
  Serial.println("VIBRATION RESULT");
  Serial.println("------------------------------------------------------------");

  Serial.print("Vibration RMS       : ");
  Serial.print(vibrationRMS, 3);
  Serial.println(" m/s^2");

  Serial.print("Vibration G         : ");
  Serial.print(vibrationG, 4);
  Serial.println(" g");

  Serial.print("Vibration Peak      : ");
  Serial.print(vibrationPeak, 3);
  Serial.println(" m/s^2");

  Serial.print("Peak-to-Peak Mag    : ");
  Serial.print(magnitudePeakToPeak, 3);
  Serial.println(" m/s^2");

  Serial.print("Vibration Status    : ");
  Serial.println(vibrationStatus);

  Serial.println("------------------------------------------------------------");
  Serial.println("UDP JSON PAYLOAD");
  Serial.println("------------------------------------------------------------");
  Serial.println(payload);

  Serial.println("============================================================");
}

// =======================
// Setup
// =======================
void setup() {
  Serial.begin(115200);
  delay(2000);

  Serial.println("====================================");
  Serial.println("MPU6050 Vibration UDP Node Starting");
  Serial.println("====================================");

  if (WiFi.status() == WL_NO_MODULE) {
    Serial.println("WiFi module not found!");
    while (1) {
      delay(1000);
    }
  }

  Serial.print("WiFiNINA firmware version: ");
  Serial.println(WiFi.firmwareVersion());

  connectWiFi();

  udp.begin(localPort);
  Serial.print("UDP started on local port: ");
  Serial.println(localPort);

  initAccelerometer();

  calibrateBaseline();

  Serial.println();
  Serial.println("System ready. Sending vibration data...");
}

// =======================
// Loop
// =======================
void loop() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi disconnected. Reconnecting...");
    connectWiFi();
  }

  float ax = 0.0;
  float ay = 0.0;
  float az = 0.0;
  float accelMagnitude = 0.0;

  float vibrationRMS = 0.0;
  float vibrationPeak = 0.0;
  float magnitudePeakToPeak = 0.0;

  int validSamples = 0;

  bool accelOK = measureVibration(
    ax,
    ay,
    az,
    accelMagnitude,
    vibrationRMS,
    vibrationPeak,
    magnitudePeakToPeak,
    validSamples
  );

  if (!accelOK) {
    String errorPayload = "{";
    errorPayload += "\"device\":\"vibration_node\",";
    errorPayload += "\"accelerometer_available\":false,";
    errorPayload += "\"status\":\"SENSOR_READ_ERROR\"";
    errorPayload += "}";

    sendUDP(errorPayload);

    Serial.println();
    Serial.println("============================================================");
    Serial.println("ERROR: SENSOR READ ERROR");
    Serial.println(errorPayload);
    Serial.println("============================================================");

    delay(500);
    return;
  }

  float vibrationG = vibrationRMS / G;
  String vibrationStatus = getVibrationStatus(vibrationRMS);

  String payload = "{";
  payload += "\"device\":\"vibration_node\",";
  payload += "\"accelerometer_available\":true,";
  payload += "\"samples\":" + String(validSamples) + ",";
  payload += "\"ax\":" + String(ax, 3) + ",";
  payload += "\"ay\":" + String(ay, 3) + ",";
  payload += "\"az\":" + String(az, 3) + ",";
  payload += "\"accel_magnitude\":" + String(accelMagnitude, 3) + ",";
  payload += "\"baseline_magnitude\":" + String(baselineMagnitude, 3) + ",";
  payload += "\"vibration_rms\":" + String(vibrationRMS, 3) + ",";
  payload += "\"vibration_g\":" + String(vibrationG, 4) + ",";
  payload += "\"vibration_peak\":" + String(vibrationPeak, 3) + ",";
  payload += "\"magnitude_peak_to_peak\":" + String(magnitudePeakToPeak, 3) + ",";
  payload += "\"vibration_status\":\"" + vibrationStatus + "\"";
  payload += "}";

  sendUDP(payload);

  printOrganizedData(
    ax,
    ay,
    az,
    accelMagnitude,
    vibrationRMS,
    vibrationG,
    vibrationPeak,
    magnitudePeakToPeak,
    vibrationStatus,
    validSamples,
    payload
  );
}
